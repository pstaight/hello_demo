[Unit]
Description=Hello World HTTPS server
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/hello_server
WorkingDirectory=/etc/hello_server
Restart=on-failure
RestartSec=5

# Run as an unprivileged user but still allow binding to port 443
User=hello_server
Group=hello_server
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
